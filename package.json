{
  "name": "neda-study-assistant",
  "version": "2.0.0",
  "description": "A birthday gift study assistant for Neda ❤️",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "electron": "cross-env NODE_ENV=development electron .",
    "electron:dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && npm run electron\"",
    "electron:build": "node scripts/write-keys.js && npm run build && electron-builder",
    "electron:build:mac": "node scripts/write-keys.js && npm run build && electron-builder --mac",
    "electron:build:win": "node scripts/write-keys.js && npm run build && electron-builder --win --x64"
  },
  "keywords": [
    "study",
    "assistant",
    "pdf",
    "flashcards"
  ],
  "author": "With Love ❤️",
  "license": "MIT",
  "type": "commonjs",
  "dependencies": {
    "@pinecone-database/pinecone": "^7.1.0",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.36.0",
    "lucide-react": "^0.577.0",
    "openai": "^6.27.0",
    "pdf-parse": "^2.4.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "dotenv": "^16.6.1",
    "electron": "^40.8.1",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "wait-on": "^9.0.4"
  },
  "build": {
    "appId": "com.neda.study-assistant.v2",
    "productName": "Nedai",
    "publish": {
      "provider": "github",
      "owner": "domantasjo",
      "repo": "study-assistant"
    },
    "copyright": "Made with ❤️",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis"
      ]
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.education"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "allowElevation": true
    }
  }
}
